# ============================================================
# AI Decision Intelligence System — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── LLM (Anthropic Claude) ──────────────────────────────────
# Required for AI-powered narrative explanations.
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── API Authentication (optional) ───────────────────────────
# If api.enable_auth is true in config.yaml, set a strong key here.
API_KEY=your-strong-api-key-here

# ── AWS Credentials ─────────────────────────────────────────
# Prefer IAM roles in production. Use these for local development only.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# ── AWS Resource Names ──────────────────────────────────────
# Override config.yaml values at runtime if needed.
AWS_BUCKET_NAME=ai-decision-intelligence-yourname
AWS_GLUE_JOB_NAME=ai-decision-intelligence-etl
AWS_LAMBDA_FUNCTION_NAME=ai-decision-intelligence-runner
AWS_EVENTBRIDGE_RULE=ai-decision-intelligence-daily
AWS_ATHENA_DATABASE=ai_decision_intelligence
