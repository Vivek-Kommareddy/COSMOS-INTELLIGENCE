# Ignore git
.git/
.gitignore

# Exclude documentation per user request (Don't add readme or claude related files)
*.md
CLAUDE*
AGENTS*
docs/

# Ignore Python specific files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/

# Ignore Node.js
node_modules/
npm-debug.log*

# Test and coverage artifacts
.pytest_cache/

# Ignore local outputs
outputs/
data/raw/
data/processed/
data/synthetic/

# Ignore local environment variables
.env
.env.local

# System/OS files
.DS_Store
